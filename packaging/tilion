#!/usr/bin/env bash
# Tilion Fortress launcher - runs the stealth Chromium with a coherent default
# Windows persona + bundled fonts. Override any --uxr-* by passing your own.
# Env: TILION_NO_DEFAULTS=1 (skip default persona)  TILION_TZ / TILION_LANG (tweak)
set -e
HERE="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
CACHE="${XDG_CACHE_HOME:-$HOME/.cache}/tilion"; mkdir -p "$CACHE/fc"
CONF="$CACHE/fonts.conf"
sed -e "s|@FONTDIR@|$HERE/fonts|g" -e "s|@CACHEDIR@|$CACHE/fc|g" "$HERE/fonts/fonts.conf.template" > "$CONF"
export FONTCONFIG_FILE="$CONF"
export VK_ICD_FILENAMES="$HERE/vk_swiftshader_icd.json"
# Set process TZ to the persona timezone so it is coherent from the FIRST tick
# (the in-renderer tz override lands async — early getTimezoneOffset() would leak the host tz).
export TZ="${TILION_TZ:-America/New_York}"
# Drop operator flags that break persona coherence. --user-agent early-returns in
# GetUserAgentMetadata() and silently drops all UA Client Hints; --enable-automation adds automation tells.
ARGS=()
for a in "$@"; do
  case "$a" in
    --user-agent|--user-agent=*) echo "tilion: ignoring '$a' - use --uxr-ua-* (it desyncs UA string vs Client Hints)" >&2 ;;
    --enable-automation) echo "tilion: ignoring --enable-automation (automation tell)" >&2 ;;
    *) ARGS+=("$a") ;;
  esac
done
DEF=()
if [ -z "$TILION_NO_DEFAULTS" ]; then
  DEF=(
    "--uxr-platform=Win32" "--uxr-ua-platform=Windows" "--uxr-ua-os=Windows NT 10.0; Win64; x64"
    "--uxr-ua-arch=x86" "--uxr-ua-bitness=64" "--uxr-ua-platform-version=15.0.0" "--uxr-ua-brand=Google Chrome"
    "--uxr-hw-concurrency=16" "--uxr-device-memory=8"
    "--uxr-webgl-vendor=Google Inc. (NVIDIA)"
    "--uxr-webgl-renderer=ANGLE (NVIDIA, NVIDIA GeForce RTX 3060 Direct3D11 vs_5_0 ps_5_0, D3D11)"
    "--uxr-webgl-fullparams=1" "--uxr-canvas-seed=778899" "--uxr-audio-seed=445566"
    "--uxr-timezone=${TILION_TZ:-America/New_York}" "--uxr-languages=${TILION_LANG:-en-US,en}"
    "--accept-lang=${TILION_LANG:-en-US,en}" "--uxr-screen-width=1920" "--uxr-screen-height=1080"
    "--uxr-webrtc-policy=disable_non_proxied_udp"
  )
fi
exec "$HERE/chrome" --use-angle=swiftshader --enable-unsafe-webgpu --enable-features=Vulkan --use-webgpu-adapter=swiftshader --enable-dawn-features=use_vulkan --uxr-webgpu-vendor=nvidia --uxr-webgpu-architecture=ampere "--uxr-webgpu-description=NVIDIA GeForce RTX 3060" "${DEF[@]}" "${ARGS[@]}"
