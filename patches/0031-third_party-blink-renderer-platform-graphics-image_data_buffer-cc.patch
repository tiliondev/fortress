+        z ^= z >> 16;
+        const int nv = static_cast<int>(v) + ((z & 1u) ? 1 : -1);
+        *p = static_cast<uint8_t>(nv < 0 ? 0 : (nv > 255 ? 255 : nv));
+      }
+    }
+  }
