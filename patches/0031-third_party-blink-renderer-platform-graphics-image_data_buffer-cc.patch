+  // StringToUint, fail-closed on invalid/zero, value-dependent + per-channel.
+  if (!base::StringToUint(
+          base::UxrConfig::GetInstance().Get("uxr-canvas-seed"), &seed) ||
+      seed == 0u) {
+    return;
+  }
