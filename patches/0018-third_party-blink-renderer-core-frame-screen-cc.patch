 namespace blink {
 
+namespace {
+// TILION Layer 2: persona screen metrics via cmdline (avoid headless 800x600 default;
+// avail* fall back to screen dims so setting just width/height stays coherent).
+bool UxrScreenInt(const char* sw, int* out) {
+  if (!base::UxrConfig::GetInstance().Has(sw)) {
+    return false;
+  }
+  int v = 0;
+  if (!base::UxrConfig::GetInstance().GetInt(sw, &v) || v <= 0) {
+    return false;
+  }
+  *out = v;
+  return true;
+}
+}  // namespace
+
+
 Screen::Screen(LocalDOMWindow* window, int64_t display_id)
     : ExecutionContextClient(window), display_id_(display_id) {}
 
