+// TILION Layer 2: seeded sub-perceptual analyser farble. Same seed+index function
+// used by BOTH float and byte paths so the two representations stay mutually
+// coherent (cross-path agreement; deterministic per session-seed).
+bool UxrAudioSeed(uint32_t* out) {
+  if (!base::UxrConfig::GetInstance().Has("uxr-audio-seed")) {
+    return false;
+  }
+  uint32_t sd = 0u;
+  if (!base::StringToUint(base::UxrConfig::GetInstance().Get("uxr-audio-seed"), &sd)) {
+    sd = 0u;
+  }
+  if (sd == 0u) {
+    sd = 0x9e3779b9u;
+  }
+  *out = sd;
+  return true;
+}
+double UxrAudioDelta(uint32_t seed, unsigned i) {
+  uint32_t st = seed ^ (i * 0x9e3779b9u + 0x85ebca6bu);
+  st ^= st << 13;
+  st ^= st >> 17;
+  st ^= st << 5;
+  double r = (st & 0xFFFFFFu) / static_cast<double>(0x1000000);
+  return (r - 0.5) * 2.0e-4;  // ~+/-1e-4 dB, inaudible
+}
