+void AudioBuffer::MaybeFarbleForUxr() {
+  if (uxr_audio_farbled_) {
+    return;
+  }
+  if (!base::UxrConfig::GetInstance().Has("uxr-audio-seed")) {
+    return;
+  }
+  uxr_audio_farbled_ = true;  // farble once; repeated reads stay stable
+  uint32_t seed = 0u;
+  if (!base::StringToUint(base::UxrConfig::GetInstance().Get("uxr-audio-seed"), &seed)) {
+    seed = 0u;
+  }
+  if (seed == 0u) {
+    seed = 0x9e3779b9u;
+  }
+  for (unsigned c = 0; c < channels_.size(); ++c) {
+    if (!channels_[c]) {
+      continue;
+    }
+    base::span<float> data = channels_[c]->AsSpan();
+    uint32_t st = seed ^ (c * 0x85ebca6bu + 0x165667b1u);
+    for (size_t i = 0; i < data.size(); ++i) {
+      st ^= st << 13;
+      st ^= st >> 17;
+      st ^= st << 5;
+      float r = (st & 0xFFFFFFu) / static_cast<float>(0x1000000);
+      data[i] += (r - 0.5f) * 2.0e-7f;  // sub-perceptual, deterministic per seed
+    }
+  }
+}
